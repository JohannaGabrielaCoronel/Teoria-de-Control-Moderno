4.3.5 Fundamentos de los modelos en espacio de estados
% Parámetros del circuito
R = 100;      % Resistencia (ohmios)
L = 0.1;      % Inductancia (henrios)
Cap = 1e-6;   % Capacitancia (faradios)

A = [0 1/Cap; -1/L -R/L];   % Matriz de estado
B = [0; 1/L];               % Entrada
C = [1 0];                  % Salida (corriente en el inductor)
D = 0;

ts = 0.015;       % Tiempo de simulación
u = 1;            % Escalón (entrada constante = 1)
xo = [0; 0];      % Condiciones iniciales

% Resolver con ode45
[t, X] = ode45(@(t,x) modelRLC(t, x, A, B, u), [0 ts], xo);

% Calcular salida
y = (C * X') + D * u;  

% Graficar respuesta al escalón
figure;
plot(t, y, 'LineWidth', 2);
grid on;
xlabel('Tiempo [s]');
ylabel('Voltaje Capacitor [V]');
title('Respuesta al escalón del circuito RLC, usando ode45');

4.3.6 Respuesta a una señal arbitraria
% Parámetros del circuito
R = 100;      
L = 0.1;      
Cap = 1e-6;   

A = [0 1/Cap; -1/L -R/L];   
B = [0; 1/L];               
C = [1 0];                  
D = 0;

% Tiempo
t = 0:0.001:0.05;   % vector de tiempo
x = [0; 0];         % condiciones iniciales

% Definir señal arbitraria por tramos
u = zeros(size(t));

for k = 1:length(t)
    if t(k) < 0.01
        u(k) = 0;
    elseif t(k) < 0.02
        u(k) = 5;
    elseif t(k) < 0.03
        u(k) = 10;
    else
        u(k) = 7;
    end
end

% Simulación con ode45
y = zeros(size(t));

for k = 1:length(t)-1
    [ts, xs] = ode45(@(t,x) modelRLC(t, x, A, B, u(k)), [t(k) t(k+1)], x);
    x = xs(end, :)';         % actualizar estado
    y(k+1) = C*x + D*u(k);   % salida
end

% Graficar
figure;
plot(t, y, 'LineWidth', 2);
grid on;
xlabel('Tiempo [s]');
ylabel('Vc [V]');
title('Respuesta del sistema a una señal arbitraria');

Función del sistema
function dx = modelRLC(t, x, A, B, u)
    dx = A * x + B * u;
end
