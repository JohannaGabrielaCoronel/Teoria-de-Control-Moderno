B = [0; 1/L];                   % Matriz de entrada
Cy = [0 1];                    % Matriz de Salida
D = 0;                          % Matriz de transferencia directa

% 1. Obtenga la función de transferencia de la corriente del circuito RLC
% usando ss2tf
[num, den] = ss2tf(A, B, Cy, D);
TF = tf(num, den);

% 2. Gráfique su respuesta al escalón
figure;
step(TF);
xlabel('Time [s]');
ylabel('i [A]');
title('Respuesta al Escalón con funcion de transferencia del segundo estado');

% 3. Convierta la función de transferencia a un modelo en espacio de
% estados
[num, den] = tfdata(TF);
[A2, B2, C2, D2] = tf2ss(num{1}, den{1});
EE3 = ss(A2, B2, C2, D2);

% 4. Gráfique su respuesta al escalón
figure;
step(EE3);
xlabel('Time [s]');
ylabel('i [A]');
title('Respuesta al Escalón con espacio de estados a partir de TF');


