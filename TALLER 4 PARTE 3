R = 100;           % Ohmios
L = 0.1;           % Henrios
Cap = 1e-6;        % Faradios

A = [0 1; -1/(L*Cap) -R/L];
B = [0; 1/L];
C = [1/Cap 0];
D = 0;

% ------------------------------------------------------
% Parámetros de simulación
% ------------------------------------------------------
fs = 100000;              
tspan = 0:1/fs:0.05;      
N = length(tspan);

% ------------------------------------------------------
% Señal arbitraria de entrada (tipo escalón múltiple)
% ------------------------------------------------------
u = zeros(size(tspan));
u(tspan >= 0.015 & tspan < 0.03) = 5;   % Primer escalón
u(tspan >= 0.03) = 10;                 % Segundo escalón

% ------------------------------------------------------
% Simulación del sistema en espacio de estados
% ------------------------------------------------------
X = zeros(N,2);   % Estados: [q, i]
t = zeros(1,N);

for k = 2:N
    [tk, Xk] = ode45(@(t,x) modelRLC(t, x, A, B, u(k-1)), ...
                     [tspan(k-1), tspan(k)], X(k-1,:));
    t(k) = tk(end);
    X(k,:) = Xk(end,:);
end

% ------------------------------------------------------
% Cálculo de la salida (voltaje del capacitor)
% ------------------------------------------------------
y = (C * X.' + D * u).';  % Salida

% ------------------------------------------------------
% Gráfica: respuesta del sistema
% ------------------------------------------------------
figure;
plot(t, y, 'LineWidth', 1.3);
grid on
xlabel('Time [s]')
ylabel('Vc [V]')
title('Respuesta del sistema a una señal arbitraria')
set(gca, 'FontSize', 11)

% ------------------------------------------------------
% Función dinámica del RLC
% ------------------------------------------------------
function dx = modelRLC(t, x, A, B, u)
    dx = A*x + B*u;
end
